  "scripts": {
    "build": "npm run build:site",
    "build:site": "node tools/build-site.mjs && webpack --config tools/webpack.config.cjs",
    "build:web": "npm run build:site && node tools/build-mobile.mjs",
    "android:sync": "npm run build:web && npx cap sync android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:release": "npm run android:sync && if not exist releases\\android mkdir releases\\android && cd android && gradlew.bat --no-daemon --no-problems-report assembleRelease && copy /Y app\\build\\outputs\\apk\\release\\app-release.apk ..\\releases\\android\\HGK-Dashboard.apk",
    "desktop:start": "electron .",
    "desktop:build": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-desktop-light.ps1",
    "desktop:build:electron": "npm run build:site && node tools/build-desktop.mjs",
    "rwp": "webpack --config tools/webpack.config.cjs"
  },
