  "build": {
    "appId": "com.hgktech.dashboard.desktop",
    "productName": "HGK Dashboard",
    "artifactName": "HGK-Dashboard-Setup-${version}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist-windows"
    },
    "files": [
      "dist/dashboard.html",
      "dist/dashboard.css",
      "dist/bundle.dashboard.js",
      "dist/supabase-config.js",
      "dist/assinatura-email-hgk-compativel.html",
      "dist/assets/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "icon": "desktop/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HGK Dashboard"
    }
  }
